# 复制此文件为 .env 并填写实际配置
# cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=123456
MYSQL_VERSION=8.0.33

# Redis
REDIS_VERSION=7.2

# Nacos
NACOS_VERSION=v2.3.2

# RocketMQ
ROCKETMQ_VERSION=5.1.4

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_VERSION=RELEASE.2024-01-01T00-00-00Z

# JWT 密钥（至少 32 位）
JWT_SECRET=takeout-system-secret-key-2024-xxxx

# 应用版本（用于 Docker 镜像标签）
APP_VERSION=1.0.0-SNAPSHOT
